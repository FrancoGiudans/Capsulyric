<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.IslandLyrics" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Primary Brand Colors -->
        <item name="colorPrimary">#277AF7</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#338FE4</item>
        <item name="colorOnPrimaryContainer">#FFFFFF</item>

        <!-- Secondary -->
        <item name="colorSecondary">#505050</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#434343</item>
        <item name="colorOnSecondaryContainer">#D9D9D9</item>

        <!-- Tertiary -->
        <item name="colorTertiary">#4788FF</item>
        <item name="colorOnTertiary">#FFFFFF</item>
        <item name="colorTertiaryContainer">#2B3B54</item>
        <item name="colorOnTertiaryContainer">#4788FF</item>

        <!-- Surface & Background -->
        <item name="colorSurface">#000000</item>
        <item name="colorOnSurface">#F2F2F2</item>
        <item name="colorSurfaceVariant">#242424</item>
        <item name="colorOnSurfaceVariant">#CCFFFFFF</item>
        <item name="colorSurfaceContainer">#242424</item>
        <item name="colorSurfaceContainerLow">#1A1A1A</item>
        <item name="colorSurfaceContainerLowest">#0A0A0A</item>
        <item name="android:colorBackground">#242424</item>

        <!-- Outline -->
        <item name="colorOutline">#404040</item>
        <item name="colorOutlineVariant">#393939</item>

        <!-- Inverse -->
        <item name="colorSurfaceInverse">#FFFFFF</item>
        <item name="colorOnSurfaceInverse">#000000</item>
        <item name="colorPrimaryInverse">#3482FF</item>
    </style>
</resources>
