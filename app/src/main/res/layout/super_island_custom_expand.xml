<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/custom_expand_cover"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/custom_expand_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="3dp"
                android:maxLines="4"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/custom_expand_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/custom_expand_miplay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:layout_gravity="top"
            android:background="@android:color/transparent"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_miplay"
            android:tint="@android:color/white" />
    </LinearLayout>

    <ImageView
        android:id="@+id/custom_expand_progress"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="14dp"
        android:scaleType="fitXY"
        android:src="@drawable/ic_music_note" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/custom_expand_prev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="18dp"
            android:background="@android:color/transparent"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_skip_previous"
            android:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/custom_expand_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="18dp"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_pause"
            android:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/custom_expand_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_skip_next"
            android:tint="@android:color/white" />
    </LinearLayout>
</LinearLayout>
